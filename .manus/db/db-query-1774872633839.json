  "query": "\n-- 2. Distribuição por universo + rating\nSELECT \n  CASE WHEN indexador LIKE '%IPCA%' THEN 'IPCA+' ELSE 'DI+' END as universo,\n  rating,\n  COUNT(*) as total,\n  SUM(CASE WHEN isOutlier = 1 THEN 1 ELSE 0 END) as outliers,\n  SUM(CASE WHEN isOutlier = 0 THEN 1 ELSE 0 END) as limpos,\n  ROUND(MIN(scoreMatch),3) as score_min,\n  ROUND(AVG(scoreMatch),3) as score_medio,\n  ROUND(AVG(zspread)*10000,0) as spread_medio_bps,\n  ROUND(MIN(zspread)*10000,0) as spread_min_bps,\n  ROUND(MAX(zspread)*10000,0) as spread_max_bps\nFROM spread_analysis\nGROUP BY universo, rating\nORDER BY universo, rating;\n",
